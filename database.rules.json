{
  "rules": {
    "stats": {
      "visits": {
        ".read": true,
        ".write": true,
        ".validate": "newData.isNumber()"
      }
    },

    "content": {
      ".read": true,
      ".write": true,
      "hero":    { "tagline": { ".validate": "newData.isString() && newData.val().length <= 160" } },
      "about": {
        "text":   { ".validate": "newData.isString() && newData.val().length <= 5000" },
        "skills": { ".validate": "newData.exists()" }
      },
      "contact": {
        "email":     { ".validate": "newData.isString() && newData.val().length <= 160" },
        "instagram": { ".validate": "newData.isString() && newData.val().length <= 400" },
        "vinted":    { ".validate": "newData.isString() && newData.val().length <= 400" }
      }
    },

    "albums": {
      ".read": true,
      ".write": true,
      "$album": {
        "title":       { ".validate": "newData.isString() && newData.val().length <= 160" },
        "category":    { ".validate": "newData.isString() && newData.val().length <= 60" },
        "description": { ".validate": "newData.isString() && newData.val().length <= 2000" },
        "link":        { ".validate": "newData.isString() && newData.val().length <= 600" },
        "cover":       { ".validate": "newData.isString() && newData.val().length <= 3000000" },
        "coverThumb":  { ".validate": "newData.isString() && newData.val().length <= 3000000" },
        "count":       { ".validate": "newData.isNumber()" },
        "cv":          { ".validate": "newData.isNumber()" },
        "coverId":     { ".validate": "newData.isString() && newData.val().length <= 60" },
        "order":       { ".validate": "newData.isNumber()" },
        "createdAt":   { ".validate": "newData.isNumber()" },
        "migrated":    { ".validate": "newData.isBoolean()" },
        "photos": {
          "$photo": {
            "src":       { ".validate": "newData.isString() && newData.val().length <= 3000000" },
            "youtube":   { ".validate": "newData.isString() && newData.val().length <= 40" },
            "title":     { ".validate": "newData.isString() && newData.val().length <= 200" },
            "order":     { ".validate": "newData.isNumber()" },
            "createdAt": { ".validate": "newData.isNumber()" },
            "$other":    { ".validate": false }
          }
        },
        "$other": { ".validate": false }
      }
    },

    "albumPhotos": {
      ".read": true,
      ".write": true,
      "$album": {
        "$photo": {
          "src":       { ".validate": "newData.isString() && newData.val().length <= 3000000" },
          "youtube":   { ".validate": "newData.isString() && newData.val().length <= 40" },
          "title":     { ".validate": "newData.isString() && newData.val().length <= 200" },
          "order":     { ".validate": "newData.isNumber()" },
          "createdAt": { ".validate": "newData.isNumber()" },
          "$other":    { ".validate": false }
        }
      }
    },

    "youtube": {
      ".read": true,
      ".write": true,
      "$v": {
        "vid":       { ".validate": "newData.isString() && newData.val().length <= 40" },
        "title":     { ".validate": "newData.isString() && newData.val().length <= 200" },
        "order":     { ".validate": "newData.isNumber()" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "$other":    { ".validate": false }
      }
    },

    "timeline": {
      ".read": true,
      ".write": true,
      "$e": {
        "year":      { ".validate": "newData.isString() && newData.val().length <= 40" },
        "title":     { ".validate": "newData.isString() && newData.val().length <= 160" },
        "text":      { ".validate": "newData.isString() && newData.val().length <= 2000" },
        "order":     { ".validate": "newData.isNumber()" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "$other":    { ".validate": false }
      }
    },

    "textes": {
      ".read": true,
      ".write": true,
      "$t": {
        "title":     { ".validate": "newData.isString() && newData.val().length <= 200" },
        "type":      { ".validate": "newData.isString() && newData.val().length <= 60" },
        "body":      { ".validate": "newData.isString() && newData.val().length <= 30000" },
        "order":     { ".validate": "newData.isNumber()" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "$other":    { ".validate": false }
      }
    },

    "inspirations": {
      ".read": true,
      ".write": true,
      "$i": {
        "kind":      { ".validate": "newData.isString() && newData.val().length <= 20" },
        "source":    { ".validate": "newData.isString() && newData.val().length <= 20" },
        "embed":     { ".validate": "newData.isString() && newData.val().length <= 800" },
        "h":         { ".validate": "newData.isNumber()" },
        "url":       { ".validate": "newData.isString() && newData.val().length <= 800" },
        "title":     { ".validate": "newData.isString() && newData.val().length <= 200" },
        "subtitle":  { ".validate": "newData.isString() && newData.val().length <= 200" },
        "cover":     { ".validate": "newData.isString() && newData.val().length <= 3000000" },
        "order":     { ".validate": "newData.isNumber()" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "$other":    { ".validate": false }
      }
    },

    "guestbook": {
      ".read": true,
      ".write": false,
      "$msg": {
        ".write": true,
        ".validate": "newData.hasChildren(['name','message','createdAt'])",
        "name":      { ".validate": "newData.isString() && newData.val().length <= 40" },
        "message":   { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 280" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "$other":    { ".validate": false }
      }
    }
  }
}
